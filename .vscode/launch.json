  "version": "0.2.0",
  "configurations": [
    {
      "name": "Service",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm start:dev",
      "env": {
        "NODE_ENV": "development"
      },
      "skipFiles": ["<node_modules>/**"],
    },
  ],
  "debug.javascript.terminalOptions": {
    "skipFiles": ["<node_internals>/**"]
  }
}
